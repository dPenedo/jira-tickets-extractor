JIRA_EMAIL=you@example.com
JIRA_TOKEN=your_atlassian_api_token
JIRA_DOMAIN=https://your-domain.atlassian.net

# Directory where ticket markdown files are saved (organized by project key)
TICKETS_DIR=/path/to/your/tickets

# Directory fzf will browse when using -t flag
REPOS_DIR=/path/to/your/repos

# Markdown file where checkbox tasks are appended when using -a flag
TASKS_FILE=~/path/to/tasks.md
